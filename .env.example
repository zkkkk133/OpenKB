# LLM API key (required) — works with any LiteLLM-supported provider
# OpenAI:    LLM_API_KEY=sk-...
# Anthropic: LLM_API_KEY=sk-ant-...
# Gemini:    LLM_API_KEY=AIza...
LLM_API_KEY=your-key-here

# Optional OpenAI-compatible proxy/base URL
# LLM_BASE_URL=https://your-proxy.example.com/v1

# Optional cache switch used by CLI add and the FastAPI service.
# Set to false to force re-ingest duplicate files and bypass service query cache.
# OPENKB_USE_CACHE=true
